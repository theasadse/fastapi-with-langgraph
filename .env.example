# Required: intent analysis, follow-up questions, and product results use OpenAI.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Recommended: search current product and retailer pages before structuring results.
OPENAI_ENABLE_WEB_SEARCH=true

# Optional: also use OpenAI for non-product answer synthesis.
AGENT_USE_OPENAI=true
